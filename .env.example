# ─────────────────────────────────────────────────────────────────────────────
# CVE Management Platform — environment template
# Copy to .env and fill in real values before running.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=cve_management
POSTGRES_USER=cve_user
POSTGRES_PASSWORD=change_me_strong_password

# Connection string used directly by the Python backend
DATABASE_URL=postgresql://cve_user:change_me_strong_password@localhost:5433/cve_management

# ── Valkey / Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6380

# ── CVE Data Sources ──────────────────────────────────────────────────────────

# NIST NVD API key — optional but strongly recommended (raises limit to 50 req/30s)
# Register: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# VulnCheck API key — required for NVD++ ingestion (primary CVE source)
# Register: https://vulncheck.com  (free community tier available)
VULNCHECK_API_KEY=

# OpenCVE API key — optional, enables Tier-3 vendor/product polling
# Register: https://www.opencve.io
OPENCVE_API_KEY=

# vulnx (ProjectDiscovery exploitability intel) API key — optional, raises
# the rate limit substantially. Used by Sprint 1 / P1 (vulnx_refresh job)
# and Sprint 1 / P3 (/api/cves/{id}/intel?refresh=true).
VULNX_API_KEY=
VULNX_BASE_URL=https://cloud.projectdiscovery.io/api/v1
VULNX_REFRESH_INTERVAL_HOURS=24
VULNX_DAILY_LIMIT=10000
VULNX_BATCH_SIZE=50
VULNX_STALENESS_DAYS=7

# Intel endpoint cache TTL (seconds)
INTEL_CACHE_TTL_SECONDS=600

# ── OpSec — Sprint 1 / P10 ────────────────────────────────────────────────────
# When true (default) outbound bodies that look like asset inventory data
# (IPv4, MAC, hostname / asset_id field names) are blocked before they leave
# the perimeter. Set to false ONLY in dry-run / staging.
OPSEC_ENFORCEMENT=true

# ── Application ───────────────────────────────────────────────────────────────

# Frontend origin the backend will accept CORS requests from
ALLOWED_ORIGIN=http://localhost:3000

# ── Ports (change only if you have local port conflicts) ─────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
POSTGRES_PORT=5433
REDIS_PORT=6380

# ── Sync schedule ─────────────────────────────────────────────────────────────
# Interval in hours for incremental CVE delta sync
DELTA_SYNC_INTERVAL_HOURS=1
